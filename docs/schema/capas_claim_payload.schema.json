{
  "$id": "https://capas.local/schema/capas_claim_payload.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "claim": {
      "additionalProperties": true,
      "properties": {
        "id": {
          "description": "Claim ids must not contain HTML angle brackets or common Unicode angle-bracket homoglyphs.",
          "maxLength": 256,
          "minLength": 1,
          "pattern": "^[^<>\u02c2\u02c3\u2039\u203a\u2329-\u232a\u276c-\u276d\u27e8-\u27e9\u29fc-\u29fd\u3008-\u3009\ufe64-\ufe65\uff1c-\uff1e]*$",
          "type": "string"
        },
        "text": {
          "description": "Claim text must not contain HTML angle brackets or common Unicode angle-bracket homoglyphs because payloads may be displayed by downstream consumers.",
          "maxLength": 2000,
          "minLength": 1,
          "pattern": "^[^<>\u02c2\u02c3\u2039\u203a\u2329-\u232a\u276c-\u276d\u27e8-\u27e9\u29fc-\u29fd\u3008-\u3009\ufe64-\ufe65\uff1c-\uff1e]*$",
          "type": "string"
        },
        "type": {
          "enum": [
            "claim_transition",
            "exact_model_solution",
            "financial_metric_claim",
            "physical_accuracy",
            "reproducibility_check",
            "statistical_confidence",
            "universal_anchor_claim"
          ],
          "type": "string"
        }
      },
      "required": [
        "id",
        "type",
        "text"
      ],
      "type": "object"
    },
    "evidence": {
      "additionalProperties": true,
      "description": "Evidence fields are claim-type dependent; unsupported or missing evidence yields HOLD.",
      "properties": {
        "abs_error": {
          "minimum": 0,
          "type": "number"
        },
        "alpha": {
          "maximum": 1,
          "minimum": 0,
          "type": "number"
        },
        "anchor_mode": {
          "pattern": "^[^<>\u02c2\u02c3\u2039\u203a\u2329-\u232a\u276c-\u276d\u27e8-\u27e9\u29fc-\u29fd\u3008-\u3009\ufe64-\ufe65\uff1c-\uff1e]*$",
          "type": "string"
        },
        "artifact_available": {
          "type": "boolean"
        },
        "current_claim": {
          "description": "Optional weaker claim text for REWRITE. HTML angle brackets and common Unicode angle-bracket homoglyphs are rejected because this value can be displayed by downstream consumers.",
          "maxLength": 4000,
          "pattern": "^[^<>\u02c2\u02c3\u2039\u203a\u2329-\u232a\u276c-\u276d\u27e8-\u27e9\u29fc-\u29fd\u3008-\u3009\ufe64-\ufe65\uff1c-\uff1e]*$",
          "type": "string"
        },
        "effect_direction_confirmed": {
          "type": "boolean"
        },
        "independent_reproduction_pass": {
          "type": "boolean"
        },
        "local_property_tests_pass": {
          "type": "boolean"
        },
        "metric_period_match": {
          "type": "boolean"
        },
        "p_value": {
          "maximum": 1,
          "minimum": 0,
          "type": "number"
        },
        "physical_evidence_level": {
          "pattern": "^[^<>\u02c2\u02c3\u2039\u203a\u2329-\u232a\u276c-\u276d\u27e8-\u27e9\u29fc-\u29fd\u3008-\u3009\ufe64-\ufe65\uff1c-\uff1e]*$",
          "type": "string"
        },
        "reference_truth": {},
        "reference_value": {
          "type": "number"
        },
        "reported_value": {
          "type": "number"
        },
        "tolerance": {
          "minimum": 0,
          "type": "number"
        },
        "universal_anchor_pass": {
          "type": "boolean"
        },
        "upgrade_evidence_present": {
          "type": "boolean"
        },
        "verification_independence": {
          "pattern": "^[^<>\u02c2\u02c3\u2039\u203a\u2329-\u232a\u276c-\u276d\u27e8-\u27e9\u29fc-\u29fd\u3008-\u3009\ufe64-\ufe65\uff1c-\uff1e]*$",
          "type": "string"
        },
        "within_chemical_accuracy": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "training_evidence": {
      "additionalProperties": true,
      "description": "Optional positive-readiness packet. It never changes ACCEPT/REJECT/REWRITE/HOLD; it only controls fine_tune_ready after an ACCEPT verdict.",
      "properties": {
        "external_review": {
          "type": "boolean"
        },
        "provenance": {
          "additionalProperties": true,
          "properties": {
            "review_id": {
              "minLength": 1,
              "type": "string"
            },
            "source_urls": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "sources": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "witness_id": {
              "minLength": 1,
              "type": "string"
            }
          },
          "type": "object"
        },
        "semantic_alignment": {
          "type": "boolean"
        },
        "source_backed_evidence": {
          "type": "boolean"
        },
        "witness_independence": {
          "type": "boolean"
        }
      },
      "type": "object"
    }
  },
  "required": [
    "claim",
    "evidence"
  ],
  "title": "CAPAS external claim/evidence payload",
  "type": "object",
  "x-capas-schema-version": "capas-claim-payload-v2"
}