{
  "$id": "https://capas.local/schema/capas_claim_payload.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "claim": {
      "additionalProperties": true,
      "properties": {
        "id": {
          "maxLength": 256,
          "minLength": 1,
          "type": "string"
        },
        "text": {
          "maxLength": 4000,
          "minLength": 1,
          "type": "string"
        },
        "type": {
          "enum": [
            "claim_transition",
            "exact_model_solution",
            "physical_accuracy",
            "universal_anchor_claim"
          ],
          "type": "string"
        }
      },
      "required": [
        "id",
        "type",
        "text"
      ],
      "type": "object"
    },
    "evidence": {
      "additionalProperties": true,
      "description": "Evidence fields are claim-type dependent; unsupported or missing evidence yields HOLD.",
      "properties": {
        "abs_error": {
          "minimum": 0,
          "type": "number"
        },
        "anchor_mode": {
          "type": "string"
        },
        "current_claim": {
          "description": "Optional weaker claim text for REWRITE. Raw HTML angle brackets are rejected because this value can be displayed by downstream consumers.",
          "maxLength": 4000,
          "type": "string"
        },
        "local_property_tests_pass": {
          "type": "boolean"
        },
        "physical_evidence_level": {
          "type": "string"
        },
        "reference_truth": {},
        "tolerance": {
          "minimum": 0,
          "type": "number"
        },
        "universal_anchor_pass": {
          "type": "boolean"
        },
        "upgrade_evidence_present": {
          "type": "boolean"
        },
        "verification_independence": {
          "type": "string"
        },
        "within_chemical_accuracy": {
          "type": "boolean"
        }
      },
      "type": "object"
    }
  },
  "required": [
    "claim",
    "evidence"
  ],
  "title": "CAPAS external claim/evidence payload",
  "type": "object"
}